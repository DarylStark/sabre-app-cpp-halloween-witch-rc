{
    "name": "Sabre Witch RC",
    "image": "dast1986/slough-dev-dc-esp32:latest",
    "remoteEnv": {
        "PROMPTNAME": "SABRE-WITCH-RC",
        "LC_ALL": "C.UTF-8"
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "runArgs": [
        "--device=/dev/ttyACM0"
    ]
}
